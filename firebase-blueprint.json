{
  "entities": {
    "User": {
      "title": "User",
      "description": "Core user authentication and basic profile info.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name"]
    },
    "Profile": {
      "title": "Profile",
      "description": "Extended user profile details.",
      "type": "object",
      "properties": {
        "bio": { "type": "string" },
        "title": { "type": "string" },
        "company": { "type": "string" },
        "language": { "type": "string", "enum": ["en", "nl", "de", "fr"] }
      }
    },
    "ConnectedService": {
      "title": "Connected Service",
      "description": "Tokens and metadata for external services like Google/Discord.",
      "type": "object",
      "properties": {
        "provider": { "type": "string", "enum": ["google", "discord", "apple", "microsoft"] },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["provider", "accessToken"]
    },
    "Message": {
      "title": "Message",
      "description": "A communication log entry.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "content", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A professional connection between users.",
      "type": "object",
      "properties": {
        "userA": { "type": "string" },
        "userB": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "blocked"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userA", "userB", "status"]
    },
    "CalendarEvent": {
      "title": "Calendar Event",
      "description": "An appointment or meeting.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "startTime", "endTime"]
    },
    "File": {
      "title": "File",
      "description": "Metadata for uploaded or synced files.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "size": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "url", "createdAt"]
    },
    "AIInsight": {
      "title": "AI Insight",
      "description": "Smart summaries and insights generated by the AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["schedule", "summary", "connection"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Main user document."
    },
    "/users/{userId}/profile/public": {
      "schema": "Profile",
      "description": "Public profile details."
    },
    "/users/{userId}/services/{serviceId}": {
      "schema": "ConnectedService",
      "description": "Sensitive tokens for external APIs."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global messages collection."
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Networking links."
    },
    "/calendar/{eventId}": {
      "schema": "CalendarEvent",
      "description": "User events."
    },
    "/files/{fileId}": {
      "schema": "File",
      "description": "User files."
    },
    "/insights/{insightId}": {
      "schema": "AIInsight",
      "description": "AI generated insights."
    }
  }
}
