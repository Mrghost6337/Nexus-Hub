rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256
          && data.name is string && data.name.size() <= 128
          && data.avatarUrl is string && data.avatarUrl.size() <= 1024
          && data.createdAt == request.time;
    }

    function isValidProfile(data) {
      return (data.bio == null || (data.bio is string && data.bio.size() <= 500))
          && (data.title == null || (data.title is string && data.title.size() <= 100))
          && (data.company == null || (data.company is string && data.company.size() <= 100))
          && (data.language == null || (data.language in ['en', 'nl', 'de', 'fr']));
    }

    function isValidConnectedService(data) {
      return data.provider in ['google', 'discord', 'apple', 'microsoft']
          && data.accessToken is string && data.accessToken.size() <= 4096
          && (data.refreshToken == null || (data.refreshToken is string && data.refreshToken.size() <= 4096));
    }

    function isValidMessage(data) {
      return data.senderId == request.auth.uid
          && data.receiverId is string && isValidId(data.receiverId)
          && data.content is string && data.content.size() <= 10000
          && data.createdAt == request.time;
    }

    function isValidContact(data) {
      return (data.userA == request.auth.uid || data.userB == request.auth.uid)
          && data.status in ['pending', 'accepted', 'blocked']
          && data.createdAt == request.time;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatarUrl'])
                    && incoming().name is string
                    && incoming().avatarUrl is string;

      match /profile/public {
        allow get: if isSignedIn();
        allow write: if isOwner(userId) && isValidProfile(incoming());
      }

      match /services/{serviceId} {
        allow read, write: if isOwner(userId) && isValidConnectedService(incoming());
      }
    }

    match /messages/{messageId} {
      allow get: if isSignedIn() && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isSignedIn() && isValidMessage(incoming());
    }

    match /contacts/{contactId} {
      allow get: if isSignedIn() && (existing().userA == request.auth.uid || existing().userB == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.userA == request.auth.uid || resource.data.userB == request.auth.uid);
      allow create: if isSignedIn() && isValidContact(incoming());
      allow update: if isSignedIn() && (existing().userA == request.auth.uid || existing().userB == request.auth.uid)
                    && incoming().diff(existing()).affectedKeys().hasOnly(['status'])
                    && incoming().status in ['accepted', 'blocked'];
    }

    match /calendar/{eventId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow write: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /files/{fileId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow write: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    match /insights/{insightId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow write: if false; // System only? Or can user delete?
    }
  }
}
